{
  "AutoScalingGroupName": "<+serviceVariables.app_name>-asg",
  "MinSize": 1,
  "MaxSize": 3,
  "DesiredCapacity": 1,
  "DefaultCooldown": 300,
  "HealthCheckType": "ELB",
  "HealthCheckGracePeriod": 300,
  "VPCZoneIdentifier": "<+serviceVariables.subnet_ids>",
  "Tags": [
    {
      "Key": "Name",
      "Value": "<+serviceVariables.app_name>",
      "PropagateAtLaunch": true
    },
    {
      "Key": "Environment",
      "Value": "<+env.name>",
      "PropagateAtLaunch": true
    }
  ]
}
