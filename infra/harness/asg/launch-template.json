{
  "LaunchTemplateData": {
    "InstanceType": "t3.micro",
    "SecurityGroupIds": [
      "<+serviceVariables.security_group_id>"
    ],
    "BlockDeviceMappings": [
      {
        "DeviceName": "/dev/xvda",
        "Ebs": {
          "VolumeSize": 20,
          "VolumeType": "gp3",
          "DeleteOnTermination": true
        }
      }
    ],
    "TagSpecifications": [
      {
        "ResourceType": "instance",
        "Tags": [
          {
            "Key": "Name",
            "Value": "<+serviceVariables.app_name>"
          },
          {
            "Key": "Application",
            "Value": "<+serviceVariables.app_name>"
          }
        ]
      }
    ]
  }
}
